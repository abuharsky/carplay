<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="88dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_eq_band_row"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="16dp"
    android:paddingEnd="10dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/eqBandValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#F1F6FF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="248dp"
        android:layout_marginTop="10dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.slider.Slider
            android:id="@+id/eqBandSlider"
            android:layout_width="240dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:rotation="-90"
            android:value="0"
            android:valueFrom="-12"
            android:valueTo="12"
            android:stepSize="1"
            app:haloColor="#2690D8FF"
            app:thumbColor="#F5F8FF"
            app:thumbRadius="12dp"
            app:trackColorActive="#8FD4FF"
            app:trackColorInactive="#255D8A"
            app:trackHeight="8dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/eqBandLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#CFE0FF"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
