<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_settings_overlay_scrim">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="28dp"
        android:paddingTop="24dp"
        android:paddingEnd="28dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_settings_sheet_surface"
            android:elevation="12dp"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="28dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="64dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/closeButton"
                    style="@style/Widget.CarPlay.SecondaryButton"
                    android:layout_width="wrap_content"
                    android:layout_height="64dp"
                    android:minWidth="136dp"
                    android:text="@string/settings_close"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/settingsHeaderCenter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/saveButton"
                    app:layout_constraintStart_toEndOf="@+id/closeButton"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/settingsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_sheet_title"
                        android:textColor="@android:color/white"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/settingsSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textColor="#A9B9D7"
                        android:textSize="16sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveButton"
                    style="@style/Widget.CarPlay.PrimaryButton"
                    android:layout_width="wrap_content"
                    android:layout_height="64dp"
                    android:minWidth="220dp"
                    android:text="@string/settings_save"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/reconnectCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:visibility="gone"
                app:cardBackgroundColor="#182B41"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#358DDBFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="22dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="18dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_state_pill" />

                    <TextView
                        android:id="@+id/reconnectText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_reconnect_required"
                        android:textColor="#E8F0FF"
                        android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:baselineAligned="false"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#13202F"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#20FFFFFF"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_main_title"
                                android:textColor="@android:color/white"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/settings_main_subtitle"
                                android:textColor="#90A2C1"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="26dp"
                                android:text="@string/settings_audio_route"
                                android:textColor="#D6E4FB"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButtonToggleGroup
                                android:id="@+id/audioRouteGroup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_segment_group_surface"
                                android:padding="5dp"
                                app:checkedButton="@id/audioRouteAdapterButton"
                                app:selectionRequired="true"
                                app:singleSelection="true">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/audioRouteAdapterButton"
                                    style="@style/Widget.CarPlay.SegmentedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="72dp"
                                    android:layout_weight="1"
                                    android:text="@string/settings_audio_route_adapter" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/audioRouteCarButton"
                                    style="@style/Widget.CarPlay.SegmentedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="72dp"
                                    android:layout_weight="1"
                                    android:text="@string/settings_audio_route_car" />
                            </com.google.android.material.button.MaterialButtonToggleGroup>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="24dp"
                                android:text="@string/settings_mic_route"
                                android:textColor="#D6E4FB"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButtonToggleGroup
                                android:id="@+id/micRouteGroup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_segment_group_surface"
                                android:padding="5dp"
                                app:checkedButton="@id/micRouteAdapterButton"
                                app:selectionRequired="true"
                                app:singleSelection="true">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/micRouteAdapterButton"
                                    style="@style/Widget.CarPlay.SegmentedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="72dp"
                                    android:layout_weight="1"
                                    android:text="@string/settings_mic_route_adapter" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/micRoutePhoneButton"
                                    style="@style/Widget.CarPlay.SegmentedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="72dp"
                                    android:layout_weight="1"
                                    android:text="@string/settings_mic_route_phone" />
                            </com.google.android.material.button.MaterialButtonToggleGroup>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/micCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        app:cardBackgroundColor="#13202F"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#20FFFFFF"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_mic_title"
                                android:textColor="@android:color/white"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/settings_mic_subtitle"
                                android:textColor="#90A2C1"
                                android:textSize="14sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="22dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/settings_mic_gain"
                                    android:textColor="#D6E4FB"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/micGainValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#EFF6FF"
                                    android:textSize="16sp" />
                            </LinearLayout>

                            <com.google.android.material.slider.Slider
                                android:id="@+id/micGainSlider"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:value="1"
                                android:valueFrom="1"
                                android:valueTo="3"
                                android:stepSize="0.1"
                                app:haloColor="#2690D8FF"
                                app:thumbColor="#F5F8FF"
                                app:trackColorActive="#8FD4FF"
                                app:trackColorInactive="#255D8A" />

                            <TextView
                                android:id="@+id/micHelpText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/settings_mic_reconnect_note"
                                android:textColor="#90A2C1"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/playerCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    app:cardBackgroundColor="#13202F"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#20FFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_players_title"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/settings_players_subtitle"
                            android:textColor="#90A2C1"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/playerTypeGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:background="@drawable/bg_segment_group_surface"
                            android:padding="5dp"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/playerMediaButton"
                                style="@style/Widget.CarPlay.SegmentedButton"
                                android:layout_width="0dp"
                                android:layout_height="70dp"
                                android:layout_weight="1"
                                android:text="@string/settings_player_media" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/playerNaviButton"
                                style="@style/Widget.CarPlay.SegmentedButton"
                                android:layout_width="0dp"
                                android:layout_height="70dp"
                                android:layout_weight="1"
                                android:text="@string/settings_player_navi" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/playerSiriButton"
                                style="@style/Widget.CarPlay.SegmentedButton"
                                android:layout_width="0dp"
                                android:layout_height="70dp"
                                android:layout_weight="1"
                                android:text="@string/settings_player_siri" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/playerPhoneButton"
                                style="@style/Widget.CarPlay.SegmentedButton"
                                android:layout_width="0dp"
                                android:layout_height="70dp"
                                android:layout_weight="1"
                                android:text="@string/settings_player_phone" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/playerAlertButton"
                                style="@style/Widget.CarPlay.SegmentedButton"
                                android:layout_width="0dp"
                                android:layout_height="70dp"
                                android:layout_weight="1"
                                android:text="@string/settings_player_alert" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/playerSectionTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#F1F6FF"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <HorizontalScrollView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scrollbars="none">

                                <com.google.android.material.button.MaterialButtonToggleGroup
                                    android:id="@+id/eqPresetGroup"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_segment_group_surface"
                                    android:padding="5dp"
                                    app:selectionRequired="true"
                                    app:singleSelection="true">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/eqPresetFlatButton"
                                        style="@style/Widget.CarPlay.SegmentedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="62dp"
                                        android:text="@string/settings_eq_preset_flat" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/eqPresetLoudnessButton"
                                        style="@style/Widget.CarPlay.SegmentedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="62dp"
                                        android:text="@string/settings_eq_preset_loudness" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/eqPresetBassButton"
                                        style="@style/Widget.CarPlay.SegmentedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="62dp"
                                        android:text="@string/settings_eq_preset_bass" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/eqPresetVocalButton"
                                        style="@style/Widget.CarPlay.SegmentedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="62dp"
                                        android:text="@string/settings_eq_preset_vocal" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/eqPresetBrightButton"
                                        style="@style/Widget.CarPlay.SegmentedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="62dp"
                                        android:text="@string/settings_eq_preset_bright" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/eqPresetCustomButton"
                                        style="@style/Widget.CarPlay.SegmentedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="62dp"
                                        android:text="@string/settings_eq_preset_custom" />
                                </com.google.android.material.button.MaterialButtonToggleGroup>
                            </HorizontalScrollView>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/settings_eq_title"
                            android:textColor="#A8B9D7"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <HorizontalScrollView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:overScrollMode="never"
                                android:scrollbars="none">

                                <LinearLayout
                                    android:id="@+id/eqBandsContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal" />
                            </HorizontalScrollView>

                            <LinearLayout
                                android:layout_width="308dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="20dp"
                                android:background="@drawable/bg_eq_band_row"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/settings_gain"
                                        android:textColor="#D6E4FB"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/playerGainValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#F1F6FF"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <com.google.android.material.slider.Slider
                                    android:id="@+id/playerGainSlider"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:value="1"
                                    android:valueFrom="1"
                                    android:valueTo="3"
                                    android:stepSize="0.1"
                                    app:haloColor="#2690D8FF"
                                    app:thumbColor="#F5F8FF"
                                    app:trackColorActive="#8FD4FF"
                                    app:trackColorInactive="#255D8A" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="18dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/settings_loudness"
                                        android:textColor="#D6E4FB"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/playerLoudnessValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#F1F6FF"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <com.google.android.material.slider.Slider
                                    android:id="@+id/playerLoudnessSlider"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:value="0"
                                    android:valueFrom="0"
                                    android:valueTo="100"
                                    android:stepSize="1"
                                    app:haloColor="#2690D8FF"
                                    app:thumbColor="#F5F8FF"
                                    app:trackColorActive="#8FD4FF"
                                    app:trackColorInactive="#255D8A" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="18dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/settings_bass_boost"
                                        android:textColor="#D6E4FB"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/playerBassValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#F1F6FF"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <com.google.android.material.slider.Slider
                                    android:id="@+id/playerBassSlider"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:value="0"
                                    android:valueFrom="0"
                                    android:valueTo="100"
                                    android:stepSize="1"
                                    app:haloColor="#2690D8FF"
                                    app:thumbColor="#F5F8FF"
                                    app:trackColorActive="#8FD4FF"
                                    app:trackColorInactive="#255D8A" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
